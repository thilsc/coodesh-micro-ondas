@model MicroondasDigital.Models.MicroondasViewModel
@using MicroondasDigital.Models.Enums

@{
    ViewData["Title"] = "Micro-ondas Digital";
}
@Html.AntiForgeryToken() 

<h1>Micro-ondas Digital</h1>

<div class="row">
  <div class="col-12 col-sm-6">

    <div class="card">
        <div class="card-body">
            <form id="startForm" asp-action="@(Model.IsPaused() ? "Retomar" : "Iniciar")" method="post" class="mt-2" style="display: grid;">
                <div class="entradas" style="margin-bottom: 10px;">
                    <label class="ms-3">Tempo</label>
                    <input asp-for="TempoAquecimento" type="number" min="1" max="@(Constants.TempoAquecimentoMaxInputManual)" class="form-control d-inline w-25" disabled="@Model.IsRunning()" />
                    <span asp-validation-for="TempoAquecimento" class="text-danger ms-2"></span>
                    
                    <label class="ms-3">Potência</label>
                    <input asp-for="Potencia" type="number" min="1" max="@(Constants.PotenciaMax)" class="form-control d-inline w-25" disabled="@Model.IsRunning()" />
                    <span asp-validation-for="Potencia" class="text-danger ms-2"></span>
                </div>

                <button id="startButton" type="submit" class="btn btn-primary" disabled="@(Model.IsRunning() && !Model.IsPaused())">
                    @(Model.IsPaused() ? "Retomar" : "Iniciar")
                </button>    
            </form>

            <form id="inicioRapidoForm" asp-action="InicioRapido" method="post" class="mt-2" style="display: grid;">
                <button id="inicioRapidoButton" type="submit" class="btn btn-primary">Início Rápido</button>
            </form>

            <form id="pauseForm" asp-action="@(Model.IsPaused() ? "Parar" : "Pausar")" method="post" class="mt-2" style="display: grid;">
                <button id="pauseButton" type="submit" class="btn btn-danger" disabled="@(!Model.IsRunning())">
                    @(Model.IsPaused() ? "Parar" : "Pausar")
                </button>
            </form>

        </div>            
    </div>
  </div>

  <div class="col-12 col-sm-6">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title" style="display: flex;">
            <span class="col-8">Programas</span>
            <button id="openPrograms" class="btn btn-warning col-4" disabled="@(Model.IsRunning())">Novo...</button>
        </h5>
        <form asp-action="AquecerPipoca" method="post" class="mt-2" style="display: grid;"> <button type="submit" class="btn btn-primary" disabled="@(Model.IsRunning())">Pipoca</button></form>
        <form asp-action="AquecerLeite" method="post" class="mt-2" style="display: grid;"> <button type="submit" class="btn btn-primary" disabled="@(Model.IsRunning())">Leite</button></form>
        <form asp-action="AquecerCarne" method="post" class="mt-2" style="display: grid;"> <button type="submit" class="btn btn-primary" disabled="@(Model.IsRunning())">Carnes de boi</button></form>
        <form asp-action="AquecerFrango" method="post" class="mt-2" style="display: grid;"> <button type="submit" class="btn btn-primary" disabled="@(Model.IsRunning())">Frango</button></form>
        <form asp-action="AquecerFeijao" method="post" class="mt-2" style="display: grid;"> <button type="submit" class="btn btn-primary" disabled="@(Model.IsRunning())">Feijão</button></form>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-sm-12">
    <div id="instrucoes"></div>    
    <div id="statusContainer">
        <div id="tempo">@ViewBag.TempoFormatado</div>
        <div id="status">@Model.Status</div>
    </div>
    <div id="display">@Model.Display</div>
    <div id="log"></div>
  </div>
</div>

<style>
    .blink {
        animation: blink-animation 1s steps(1, start) infinite;
    }

    /* double the @@ so Razor outputs a single @@ */  
    @@keyframes blink-animation {
        50% { opacity: 0; }
    }
</style>

<!-- Modais para gerenciamento de programas customizados -- >
<div id="programModalContainer"></div>
-->

<script>
    let intervalo;

    function iniciarPolling() {

        if (intervalo) clearInterval(intervalo);
        
        intervalo = setInterval(() => {
    
            fetch('/Microondas/Tick', { 
                    method: 'POST',
                    headers: {  
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    }
                })
                .then(() => {
                    return fetch('/Microondas/StatusAtual');
                })
                .then(r => r.json())
                .then(data => {

                    document.getElementById('tempo').textContent = data.tempoFormatado;
                    document.getElementById('status').textContent = data.status;
                    document.getElementById('display').textContent = data.display;
                    document.getElementById('instrucoes').textContent = data.ismodoAquecimentoPadrao ? '' : data.instrucoes;

                    const startBtn = document.getElementById('startButton');
                    const inicioRapidoBtn = document.getElementById('inicioRapidoButton');
                    const pauseBtn = document.getElementById('pauseButton');
                    const tempoDiv = document.getElementById('tempo');

                    if(startBtn && pauseBtn && inicioRapidoBtn) {

                        startBtn.disabled = data.isRunning && (!data.isPaused);
                        pauseBtn.disabled = !data.isRunning;
                        inicioRapidoBtn.disabled = data.isRunning && (!data.ismodoAquecimentoPadrao);

                        if(data.isPaused) {
                            startBtn.textContent = 'Retomar';
                            startBtn.formAction = '/Microondas/Retomar';
                            pauseBtn.textContent = 'Parar';
                            pauseBtn.formAction = '/Microondas/Parar';
                        } else {
                            startBtn.textContent = 'Iniciar';
                            startBtn.formAction = '/Microondas/Iniciar';
                            pauseBtn.textContent = 'Pausar';
                            pauseBtn.formAction = '/Microondas/Pausar';
                        }
                        
                        document.querySelectorAll('form[action*="Aquecer"] button')
                                .forEach(b => b.disabled = data.isRunning);

                        if(data.isPaused) {
                            tempoDiv?.classList.add('blink');
                        } else {
                            tempoDiv?.classList.remove('blink');
                        }

                        if (!data.isRunning && intervalo) {
                            clearInterval(intervalo);
                        }
                    }
                })
                .catch(e => console.log('Polling error:', e));
        }, 1000);
    }

    iniciarPolling();

    /** Gerenciamento de programas customizados *-/
    document.getElementById('openPrograms').addEventListener('click', loadProgramList);

    function loadProgramList() {
        fetch('/Microondas/ListaProgramas', { credentials: 'same-origin' })
            .then(r => r.text())
            .then(html => {
                document.getElementById('programModalContainer').innerHTML = html;
                var modal = new bootstrap.Modal(document.getElementById('programListModal'));
                modal.show();
                attachListHandlers();
            });
    }

    function attachListHandlers() {
        const newBtn = document.getElementById('btnNewProgram');
        if (newBtn) newBtn.addEventListener('click', () => loadProgramModal());
        document.querySelectorAll('.useProgram').forEach(btn => {
            btn.addEventListener('click', () => {
                fetch('/Microondas/UsarPrograma', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${btn.dataset.id}`
                }).then(() => {
                    // after starting program, go back to index so status updates
                    window.location.reload();
                });
            });
        });
        document.querySelectorAll('.editProgram').forEach(btn => {
            btn.addEventListener('click', () => loadProgramModal(btn.dataset.id));
        });
        document.querySelectorAll('.deleteProgram').forEach(btn => {
            btn.addEventListener('click', () => {
                if (confirm('Deseja realmente excluir este programa?')) {
                    fetch('/Microondas/DeletePrograma', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `id=${btn.dataset.id}`
                    }).then(() => loadProgramList());
                }
            });
        });
    }

    function loadProgramModal(id) {
        const url = id ? `/Microondas/EditPrograma?id=${id}` : '/Microondas/CriarProgramaCustomizado';
        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('programModalContainer').innerHTML = html;
                var modalEl = document.getElementById('programModal');
                var modal = new bootstrap.Modal(modalEl);
                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const data = new FormData(form);
                    const action = form.getAttribute('action');
                    fetch(action, { method: 'POST', body: data })
                        .then(r => r.json())
                        .then(result => {
                            if (result.success) {
                                modal.hide();
                                loadProgramList();
                            } else if (result.html) {
                                // replace modal html with returned html containing errors
                                document.getElementById('programModalContainer').innerHTML = result.html;
                                // reshow and reattach
                                var newModalEl = document.getElementById('programModal');
                                var newModal = new bootstrap.Modal(newModalEl);
                                newModal.show();
                                loadProgramModalHandlers(newModalEl);
                            }
                        });
                });
            });
    }

    function loadProgramModalHandlers(modalEl) {
        const form = modalEl.querySelector('form');
        if (!form) return;
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            const data = new FormData(form);
            const action = form.getAttribute('action');
            fetch(action, { method: 'POST', body: data })
                .then(r => r.json())
                .then(result => {
                    if (result.success) {
                        var newModal = bootstrap.Modal.getInstance(modalEl);
                        newModal.hide();
                        loadProgramList();
                    } else if (result.html) {
                        document.getElementById('programModalContainer').innerHTML = result.html;
                        var newModalEl = document.getElementById('programModal');
                        var newModal = new bootstrap.Modal(newModalEl);
                        newModal.show();
                        loadProgramModalHandlers(newModalEl);
                    }
                });
        });
    }
    
    **/
}
</script>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
